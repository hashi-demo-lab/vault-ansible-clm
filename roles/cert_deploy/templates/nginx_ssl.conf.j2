# {{ ansible_managed }}
# Nginx SSL vhost configuration -- reference template
# Deploy to /etc/nginx/conf.d/ or /etc/nginx/sites-enabled/

server {
    listen 443 ssl http2;
    server_name {{ vault_cert_common_name }};

    ssl_certificate     {{ cert_dest_fullchain }};
    ssl_certificate_key {{ cert_dest_key }};

    # TLS configuration
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384;
    ssl_prefer_server_ciphers off;
    ssl_session_timeout 1d;
    ssl_session_cache shared:SSL:10m;
    ssl_session_tickets off;

    # CA chain for verification
    ssl_trusted_certificate {{ cert_dest_chain }};

    location / {
        root /usr/share/nginx/html;
        index index.html;
    }
}
